# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
# @plugin(@varlock/proton-pass-plugin@0.0.3)
# @initProtonPass()
# @defaultRequired=true @defaultSensitive=false
# ----------

# The application environment
# @type=enum(development, production)
ENVIRONMENT=development

# @type=enum(debug, info, warn, error)
LOG_LEVEL=debug

## Ports

# The port of the fastapi backend app
# @type=port
PORT=8000

# @type=port
LLM_API_PORT=8001

# @type=port
CLIENT_PORT=3000

# @type=port
WHISPER_PORT=50001

## Urls

# The URL for client application
# @type=url
CLIENT_URL=if(
    eq($ENVIRONMENT, "development"), http://localhost:${CLIENT_PORT}, )


# The URL for LLM API
# @type=url
LLM_URL=if(
    eq($ENVIRONMENT, "development"), "http://localhost:${LLM_API_PORT}/v1", )


# The url for the Whisper api
# @type=url
WHISPER_URL=if(
	eq($ENVIRONMENT, "development"), "http://localhost:${WHISPER_PORT}/v1", )

# The URL for LLM health check API
# @type=url
LLM_HEALTH_CHECK_URL=if(
    eq($ENVIRONMENT, "development"), "http://localhost:${LLM_API_PORT}/health", )

## LLM

# The model for LLM API
# @type=string
LLM_MODEL='Qwen/Qwen3-32B-AWQ'

# The API key for authenticating with OpenAI
# @sensitive=eq($ENVIRONMENT, "production")
LLM_API_KEY=none

## Secrets

# Used to pseudonymize user id. Create with openssl rand 32 | base64
# @sensitive
HMAC_SECRET=

## Flags

# Flag to indicate if the environment is production used for the logger
# @type=boolean
IS_PROD=eq($ENVIRONMENT, "production")

# For docker compose
# ---

## Docling

# only needed for the VLLM docker container
# @optional @sensitive
HUGGING_FACE_HUB_TOKEN=protonPass("pass://DCC-KI/HUGGING_FACE_TOKEN/TOKEN", allowMissing=true)

## Caching dirs for docker
CACHE_DIR="~/.cache"
HUGGING_FACE_CACHE_DIR=${CACHE_DIR}/huggingface
